                            </div>
                        </article>
                    </div>
                }
            </div>
        </div>
    </section> *@
</main>

<footer id="contact" class="footer-section">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-5">
                <h3>About Me</h3>
                <p>
                    We have tested a number of registry fix and clean utilities and present our top 3 list on our site for your convenience.
                </p>
                <p class="copyright-note">Copyright © @DateTime.UtcNow.Year All rights reserved | This template is made with ❤ by Colorlib-inspired Razor conversion.</p>
            </div>
            <div class="col-lg-4">
                <h3>Newsletter</h3>
                <p>Stay updated with our latest trends.</p>
                <form class="newsletter-form" onsubmit="return false;">
                    <div class="input-group">
                        <input type="email" class="form-control" placeholder="Enter Email Address" aria-label="Email Address">
                        <button class="btn primary-btn" type="submit">Subscribe</button>
                    </div>
                </form>
            </div>
            <div class="col-lg-3">
                <h3>Follow Me</h3>
                <p>Let us be social.</p>
                <div class="social-links">
                    <a href="#" aria-label="Facebook">Fb</a>
                    <a href="#" aria-label="Twitter">Tw</a>
                    <a href="#" aria-label="Dribbble">Dr</a>
                    <a href="#" aria-label="Behance">Be</a>
                </div>
            </div>
        </div>
    </div>
</footer>
