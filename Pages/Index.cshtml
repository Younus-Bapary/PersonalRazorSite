@page
@model IndexModel
@{
    ViewData["Title"] = "Personal";
}

<header class="site-header sticky-top">
    <nav id="mainNav" class="navbar navbar-expand-lg bg-white shadow-sm">
        <div class="container">
            <a class="navbar-brand fw-bold brand-mark" href="#home">Personal</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMenu" aria-controls="navbarMenu" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarMenu">
                <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-2 text-uppercase small fw-semibold">
                    <li class="nav-item"><a class="nav-link" href="#home">Home</a></li>
                    <li class="nav-item"><a class="nav-link" href="#about">About</a></li>
                    <li class="nav-item"><a class="nav-link" href="#services">Services</a></li>
                    <li class="nav-item"><a class="nav-link" href="#portfolio">Portfolio</a></li>
                    <li class="nav-item"><a class="nav-link" href="#pricing">Pricing</a></li>
                    @* <li class="nav-item"><a class="nav-link" href="#blog">Blog</a></li> *@
                    <li class="nav-item"><a class="nav-link" asp-page="/Contact">Contact</a></li>
                </ul>
            </div>
        </div>
    </nav>
</header>

<main>
    <section id="home" class="hero-section">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-6 order-2 order-lg-1">
                    <p class="section-kicker">THIS IS ME</p>
                    <h1 class="hero-title">MD YOUNUS BAPARY</h1>
                    <p class="hero-copy">
                        You will begin to realise why this exercise is called the Dickens Pattern with reference to the ghost showing Scrooge some different futures.
                    </p>
                    <a href="#portfolio" class="btn primary-btn px-4 py-3 text-uppercase fw-semibold">Discover Now</a>
                </div>
                <div class="col-lg-6 order-1 order-lg-2 text-center">
                    <img src="~/images/hero-illustration.svg" class="img-fluid hero-image" alt="Hero portrait" />
                </div>
            </div>
        </div>
    </section>

    <section id="about" class="section-gap">
        <div class="container">
            <div class="row align-items-center g-5">
                <div class="col-lg-6 text-center">
                    <img src="~/images/about-illustration.svg" class="img-fluid about-image" alt="About portrait" />
                </div>
                <div class="col-lg-6">
                    <p class="section-kicker">ABOUT ME</p>
                    <h2 class="section-title text-start">PERSONAL DETAILS</h2>
                    <p class="section-copy text-start">
                        Here, I focus on a range of items and features that we use in life without giving them a second thought. Such as Coca Cola. Dolor sit amet, consectetur adipisicing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
                    </p>
                    <a asp-page="/Contact" class="btn primary-btn px-4 py-3 text-uppercase fw-semibold">View Full Details</a>
                </div>
            </div>
        </div>
    </section>

    <section id="services" class="section-gap bg-light-blue">
        <div class="container">
            <div class="section-heading text-center mx-auto">
                <h2 class="section-title">My Offered Services</h2>
                <p class="section-copy">At about this time of year, some months after New Year’s resolutions have been made and kept, or made and neglected.</p>
            </div>
            <div class="row g-4 mt-4">
                @foreach (var service in new[]
                {
                    new { Title = "Web Design", Text = "It is not because things are difficult that we do not dare; it is because we do not dare that they are difficult." },
                    new { Title = "Web Development", Text = "If you are an entrepreneur, you know that your success cannot depend on the opinions of others. Like the wind, opinions." },
                    new { Title = "Photography", Text = "Do you want to be even more successful? Learn to love learning and growth. The more effort you put into improving your skills." },
                    new { Title = "Clipping Path", Text = "Hypnosis quit smoking methods maintain caused quite a stir in the medical world over the last two decades. There is a lot of argument." },
                    new { Title = "Apps Interface", Text = "Do you sometimes have the feeling that you’re running into the same obstacles over and over again? Many of my conflicts." },
                    new { Title = "Graphic Design", Text = "You’ve heard the expression, just believe it and it will come. Well, technically that is true, however believing is not just thinking." }
                })
                {
                    <div class="col-md-6 col-xl-4">
                        <article class="service-card text-center h-100">
                            <div class="service-icon">✦</div>
                            <h3>@service.Title</h3>
                            <p>@service.Text</p>
                        </article>
                    </div>
                }
            </div>
        </div>
    </section>

    <section class="stats-band">
        <div class="container">
            <div class="row text-center text-white g-4">
                <div class="col-6 col-lg-3"><div class="stat-number" data-target="2536">0</div><div class="stat-label">Projects Completed</div></div>
                <div class="col-6 col-lg-3"><div class="stat-number" data-target="6784">0</div><div class="stat-label">Happy Clients</div></div>
                <div class="col-6 col-lg-3"><div class="stat-number" data-target="2239">0</div><div class="stat-label">Cups of Coffee</div></div>
                <div class="col-6 col-lg-3"><div class="stat-number" data-target="434">0</div><div class="stat-label">Real Professionals</div></div>
            </div>
        </div>
    </section>

    <section id="portfolio" class="section-gap">
        <div class="container">
            <div class="section-heading text-center mx-auto">
                <h2 class="section-title">Our Latest Featured Projects</h2>
                <p class="section-copy">Who are in extremely love with eco friendly system.</p>
            </div>
            <div class="portfolio-filter text-center mt-4 mb-5">
                <button class="filter-btn active" data-filter="all">All</button>
                <button class="filter-btn" data-filter="vector">Vector</button>
                <button class="filter-btn" data-filter="raster">Raster</button>
                <button class="filter-btn" data-filter="uiux">UI/UX</button>
                <button class="filter-btn" data-filter="printing">Printing</button>
            </div>
            <div class="row g-4 portfolio-grid">
                @foreach (var item in new[]
                {
                    new { Category = "vector", Title = "2D Vinyl Design", Image = "portfolio-1.svg", Tag = "vector" },
                    new { Category = "raster", Title = "Creative Poster Design", Image = "portfolio-2.svg", Tag = "agency" },
                    new { Category = "uiux", Title = "Embosed Logo Design", Image = "portfolio-3.svg", Tag = "portal" },
                    new { Category = "printing", Title = "3D Helmet Design", Image = "portfolio-4.svg", Tag = "vector" },
                    new { Category = "vector", Title = "2D Vinyl Design", Image = "portfolio-5.svg", Tag = "raster" },
                    new { Category = "uiux", Title = "Creative Poster Design", Image = "portfolio-6.svg", Tag = "ui/ux" }
                })
                {
                    <div class="col-md-6 col-lg-4 portfolio-item" data-category="@item.Category">
                        <article class="portfolio-card text-center">
                            <div class="portfolio-thumb">
                                <img src="~/images/portfolio/@item.Image" class="img-fluid" alt="@item.Title" />
                            </div>
                            <h3>@item.Title</h3>
                            <p>@item.Tag</p>
                        </article>
                    </div>
                }
            </div>
        </div>
    </section>

    <section id="pricing" class="section-gap bg-light-blue">
        <div class="container">
            <div class="section-heading text-center mx-auto">
                <h2 class="section-title">Choose Your Plan</h2>
                <p class="section-copy">When someone does something that they know that they shouldn’t do, did they.</p>
            </div>
            <div class="row g-4 mt-4">
                @foreach (var plan in new[]
                {
                    new { Number = "01", Name = "Economy", Price = "$199.00", Features = new[] { "For the individuals", "Secure Online Transfer", "Unlimited Styles for interface", "Reliable Customer Service" } },
                    new { Number = "02", Name = "Business", Price = "$299.00", Features = new[] { "For the small company", "Secure Online Transfer", "Unlimited Styles for interface", "Reliable Customer Service" } },
                    new { Number = "03", Name = "Premium", Price = "$399.00", Features = new[] { "For the large company", "Secure Online Transfer", "Unlimited Styles for interface", "Reliable Customer Service" } },
                    new { Number = "04", Name = "Exclusive", Price = "$499.00", Features = new[] { "For the enterprise", "Secure Online Transfer", "Unlimited Styles for interface", "Reliable Customer Service" } }
                })
                {
                    <div class="col-md-6 col-xl-3">
                        <article class="price-card h-100 text-center">
                            <div class="plan-badge">@plan.Number</div>
                            <h3>@plan.Name</h3>
                            <p class="plan-intro">@plan.Features[0]</p>
                            <ul class="list-unstyled plan-features my-4">
                                @foreach (var feature in plan.Features.Skip(1))
                                {
                                    <li>@feature</li>
                                }
                            </ul>
                            <div class="plan-price">@plan.Price</div>
                            <a asp-page="/Contact" class="btn outline-btn text-uppercase fw-semibold mt-4">Buy Now</a>
                        </article>
                    </div>
                }
            </div>
        </div>
    </section>

   @*  <section id="blog" class="section-gap">
        <div class="container">
            <div class="section-heading text-center mx-auto">
                <h2 class="section-title">Latest Posts From Our Blog</h2>
                <p class="section-copy">You may be a skillful, effective employer but if you don’t trust your personnel and the opposite, then the chances of improving and expanding the business.</p>
            </div>
            <div class="row g-4 mt-4">
                @foreach (var post in new[]
                {
                    new { Title = "Break Through Self Doubt And Fear", Meta = "By Mark Wiens | 13th Dec", Image = "portfolio-1.svg" },
                    new { Title = "Portable Fashion for Young Women", Meta = "By Mark Wiens | 17th Dec", Image = "portfolio-2.svg" },
                    new { Title = "Do Dreams Serve As A Premonition", Meta = "By Mark Wiens | 23rd Dec", Image = "portfolio-3.svg" }
                })
                {
                    <div class="col-lg-4">
                        <article class="blog-card h-100">
                            <img src="~/images/portfolio/@post.Image" class="img-fluid blog-image" alt="@post.Title" />
